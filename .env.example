# Maket AI - Variables de Entorno

# Base de datos (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
DATABASE_URL=postgresql://postgres.tu-proyecto:tu-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Autenticación
NEXTAUTH_SECRET=genera-una-clave-secreta-aleatoria-con-openssl-rand-base64-32

# IA - OpenAI (opcional si usas Gemini)
OPENAI_API_KEY=sk-...

# IA - Google Gemini (opcional si usas OpenAI, más económico - RECOMENDADO)
GEMINI_API_KEY=AIza...

# NOTA IMPORTANTE: 
# - El sistema prioriza Gemini (más económico), luego OpenAI, finalmente keywords fallback
# - Configura al menos una API key para funcionalidad completa
# - Sin API keys, el sistema funciona con detección por palabras clave (menor confianza)
# - Para ejecutar tests completos: npx tsx src/lib/constructor/ejecutar-tests.ts

# Desarrollo
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
